# .env.example - Copy to .env and update values
# Server
PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=image_hosting

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Node Environment
NODE_ENV=production
